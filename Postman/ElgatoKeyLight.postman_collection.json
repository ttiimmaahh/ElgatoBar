{
  "info": {
    "_postman_id": "elgato-key-light-api",
    "name": "Elgato Key Light API",
    "description": "API collection for controlling Elgato Key Lights and Ring Lights.\n\nSet the `light_ip` variable to your light's IP address before making requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "light_ip",
      "value": "192.168.1.100",
      "type": "string"
    },
    {
      "key": "port",
      "value": "9123",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Discovery & Info",
      "item": [
        {
          "name": "Get Light State",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "http://{{light_ip}}:{{port}}/elgato/lights",
              "protocol": "http",
              "host": ["{{light_ip}}"],
              "port": "{{port}}",
              "path": ["elgato", "lights"]
            },
            "description": "Get the current state of the light including on/off, brightness, and temperature."
          }
        },
        {
          "name": "Get Accessory Info",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "http://{{light_ip}}:{{port}}/elgato/accessory-info",
              "protocol": "http",
              "host": ["{{light_ip}}"],
              "port": "{{port}}",
              "path": ["elgato", "accessory-info"]
            },
            "description": "Get device information including product name, firmware version, serial number, and WiFi info."
          }
        },
        {
          "name": "Get Settings",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "http://{{light_ip}}:{{port}}/elgato/settings",
              "protocol": "http",
              "host": ["{{light_ip}}"],
              "port": "{{port}}",
              "path": ["elgato", "settings"]
            },
            "description": "Get device settings and behavior configuration."
          }
        },
        {
          "name": "Identify Light",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "http://{{light_ip}}:{{port}}/elgato/identify",
              "protocol": "http",
              "host": ["{{light_ip}}"],
              "port": "{{port}}",
              "path": ["elgato", "identify"]
            },
            "description": "Flash the light a few times to identify it physically."
          }
        }
      ]
    },
    {
      "name": "Power Control",
      "item": [
        {
          "name": "Turn Light On",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lights\": [\n    {\n      \"on\": 1\n    }\n  ]\n}"
            },
            "url": {
              "raw": "http://{{light_ip}}:{{port}}/elgato/lights",
              "protocol": "http",
              "host": ["{{light_ip}}"],
              "port": "{{port}}",
              "path": ["elgato", "lights"]
            },
            "description": "Turn the light on (maintains current brightness and temperature)."
          }
        },
        {
          "name": "Turn Light Off",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lights\": [\n    {\n      \"on\": 0\n    }\n  ]\n}"
            },
            "url": {
              "raw": "http://{{light_ip}}:{{port}}/elgato/lights",
              "protocol": "http",
              "host": ["{{light_ip}}"],
              "port": "{{port}}",
              "path": ["elgato", "lights"]
            },
            "description": "Turn the light off."
          }
        },
        {
          "name": "Turn On - Full Brightness",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lights\": [\n    {\n      \"on\": 1,\n      \"brightness\": 100,\n      \"temperature\": 200\n    }\n  ]\n}"
            },
            "url": {
              "raw": "http://{{light_ip}}:{{port}}/elgato/lights",
              "protocol": "http",
              "host": ["{{light_ip}}"],
              "port": "{{port}}",
              "path": ["elgato", "lights"]
            },
            "description": "Turn on at 100% brightness with neutral color temperature (~5000K)."
          }
        }
      ]
    },
